{
    "name": "nhatnathando/laravel-api-replay",
    "description": "Log, store, and replay Laravel API requests.",
    "keywords": [
        "laravel",
        "api",
        "replay",
        "testing",
        "debug"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Nathan Do",
            "email": "dominhnhat.030402@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^9.0|^10.0|^11.0",
        "illuminate/http": "^9.0|^10.0|^11.0",
        "illuminate/database": "^9.0|^10.0|^11.0",
        "illuminate/console": "^9.0|^10.0|^11.0"
    },
    "require-dev": {
        "orchestra/testbench": "^7.0|^8.0|^9.0",
        "phpunit/phpunit": "^9.0|^10.0"
    },
    "autoload": {
        "psr-4": {
            "Storage\\ApiReplay\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Storage\\ApiReplay\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Storage\\ApiReplay\\Providers\\ApiReplayServiceProvider"
            ]
        }
    },
    "repositories": {
        "local": {
            "type": "path",
            "url": "../laravel-api-replay"
        }
    }
}